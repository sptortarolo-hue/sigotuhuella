rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For simplicity in this community app, we'll allow the owner email (sptortarolo@gmail.com)
      // to be an admin by default, but ideally we check a collection.
      return isSignedIn() && (
        request.auth.token.email == 'sptortarolo@gmail.com' ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidPet(data) {
      return data.species in ['dog', 'cat', 'other'] &&
             data.status in ['lost', 'found', 'for_adoption', 'adopted', 'reunited'] &&
             data.location is string &&
             data.location.size() <= 200 &&
             (!('coordinates' in data) || (data.coordinates.lat is number && data.coordinates.lng is number)) &&
             (!('imageUrls' in data) || (data.imageUrls is list && data.imageUrls.size() >= 1 && data.imageUrls.size() <= 3));
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Pets collection
    match /pets/{petId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                    isValidPet(request.resource.data) && 
                    request.resource.data.createdBy == request.auth.uid;
      allow update: if (isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == resource.data.createdBy && isValidPet(request.resource.data) && request.resource.data.createdBy == resource.data.createdBy)
      ));
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.createdBy);
    }

    // Collaboration Accounts
    match /collaboration_accounts/{accountId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Volunteer Requests
    match /volunteer_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
