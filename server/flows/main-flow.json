        "has_pets": { "type": "string", "__example__": "yes" },
        "alerts_optin": { "type": "string", "__example__": "yes" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "🙌 Ser voluntario"
          },
          {
            "type": "TextBody",
            "text": "Contanos un poco sobre vos para sumarte a la red."
          },
          {
            "type": "RadioButtonsGroup",
            "name": "zone",
            "label": "¿Vivís en la zona?",
            "data-source": [
              { "id": "sicardi", "title": "Sicardi" },
              { "id": "garibaldi", "title": "Garibaldi" },
              { "id": "correas", "title": "Correas" },
              { "id": "near", "title": "Zonas cercanas" },
              { "id": "other", "title": "Otra" }
            ]
          },
          {
            "type": "RadioButtonsGroup",
            "name": "has_pets",
            "label": "¿Tenés mascotas?",
            "data-source": [
              { "id": "dog", "title": "🐕 Perro/s" },
              { "id": "cat", "title": "🐱 Gato/s" },
              { "id": "both", "title": "🐾 Perro y gato" },
              { "id": "none", "title": "No tengo" }
            ]
          },
          {
            "type": "RadioButtonsGroup",
            "name": "alerts_optin",
            "label": "¿Querés recibir alertas de mascotas perdidas en tu zona?",
            "data-source": [
              { "id": "yes", "title": "✅ Sí" },
              { "id": "no", "title": "❌ No" }
            ]
          },
          {
            "type": "Footer",
            "label": "Continuar",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "VOLUNTEER_FORM"
              }
            }
          }
        ]
      }
    },
