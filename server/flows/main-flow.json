{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "MAIN_MENU": [
      "REPORT_LOST", "REPORT_SIGHTED", "REPORT_FOUND",
      "ADOPT_FILTER", "CHAPITA_INFO",
      "DONATE_INFO", "VOLUNTEER_ONBOARDING",
      "FACEBOOK_LINK", "CONTACT_FORM"
    ],
    "CHAPITA_INFO": ["CHAPITA_FORM"],
    "CHAPITA_FORM": [],
    "DONATE_INFO": ["DONATE_SHOW"],
    "DONATE_SHOW": [],
    "VOLUNTEER_ONBOARDING": ["VOLUNTEER_FORM"],
    "VOLUNTEER_FORM": [],
    "REPORT_LOST": [],
    "REPORT_SIGHTED": [],
    "REPORT_FOUND": [],
    "ADOPT_FILTER": [],
    "FACEBOOK_LINK": [],
    "CONTACT_FORM": []
  },
  "screens": [
    {
      "id": "MAIN_MENU",
      "title": "Sigo Tu Huella",
      "data": {
        "selected_option": { "type": "string", "__example__": "lost" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "🐾 Sigo Tu Huella"
          },
          {
            "type": "TextBody",
            "text": "Red Vecinal de Mascotas\nSicardi · Garibaldi · Correas\n\n¿En qué podemos ayudarte?"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "selected_option",
            "label": "Elegí una opción:",
            "data-source": [
              { "id": "lost", "title": "📷 Perdí mi mascota" },
              { "id": "sighted", "title": "👀 Vi una mascota (avistaje)" },
              { "id": "found", "title": "✅ Encontré una mascota" },
              { "id": "adopt", "title": "🙋 Quiero adoptar" },
              { "id": "chapita", "title": "ℹ️ Chapita QR" },
              { "id": "donate", "title": "💰 Donar" },
              { "id": "volunteer", "title": "🙌 Ser voluntario" },
              { "id": "facebook", "title": "📱 Link de Facebook" },
              { "id": "contact", "title": "🗣 Contactar equipo" }
            ]
          },
          {
            "type": "Footer",
            "label": "Continuar",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "REPORT_LOST",
      "title": "Perdí mi mascota",
      "data": {
        "pet_name": { "type": "string", "__example__": "Luna" },
        "species": { "type": "string", "__example__": "dog" },
        "location": { "type": "string", "__example__": "Sicardi, cerca de la plaza" },
        "description": { "type": "string", "__example__": "Color marrón, collar rojo" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "📷 Perdí mi mascota"
          },
          {
            "type": "TextInput",
            "name": "pet_name",
            "label": "Nombre de tu mascota (si sabés)"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "species",
            "label": "Especie",
            "data-source": [
              { "id": "dog", "title": "🐕 Perro" },
              { "id": "cat", "title": "🐱 Gato" },
              { "id": "other", "title": "🐾 Otro" }
            ]
          },
          {
            "type": "TextInput",
            "name": "location",
            "label": "¿Dónde se perdió?"
          },
          {
            "type": "TextArea",
            "name": "description",
            "label": "Descripción (señas particulares, color, etc.)"
          },
          {
            "type": "Footer",
            "label": "Enviar reporte",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    },
    {
