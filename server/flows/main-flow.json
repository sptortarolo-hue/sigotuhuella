    },
    {
      "id": "CONTACT_FORM",
      "title": "Contactar equipo",
      "data": {
        "name": { "type": "string", "__example__": "Juan" },
        "motive": { "type": "string", "__example__": "question" },
        "message": { "type": "string", "__example__": "Tengo una consulta sobre..." }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "🗣 Contactar equipo"
          },
          {
            "type": "TextInput",
            "label": "Tu nombre",
            "data_ref": "name",
            "placeholder": "Ej: Juan"
          },
          {
            "type": "Dropdown",
            "label": "Motivo",
            "data_ref": "motive",
            "properties": [
              { "value": "question", "display_text": "Consulta general" },
              { "value": "suggestion", "display_text": "Sugerencia" },
              { "value": "problem", "display_text": "Problema con la app" },
              { "value": "other", "display_text": "Otro" }
            ]
          },
          {
            "type": "TextArea",
            "label": "Tu mensaje",
            "data_ref": "message",
            "placeholder": "Escribí tu mensaje acá..."
          },
          {
            "type": "Footer",
            "label": "Enviar mensaje",
            "onClickAction": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
