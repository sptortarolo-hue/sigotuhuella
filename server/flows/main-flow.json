            "placeholder": "Ej: Juan Pérez"
          },
          {
            "type": "TextInput",
            "label": "Tu teléfono (sin 0 ni 15)",
            "data_ref": "phone",
            "placeholder": "Ej: 2215551234"
          },
          {
            "type": "Footer",
            "label": "Enviar y sumarme",
            "onClickAction": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "FACEBOOK_LINK",
      "title": "Link de Facebook",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "📱 Link de Facebook"
          },
          {
            "type": "TextBody",
            "text": "¿Querés vincular tu cuenta de Facebook con Sigo Tu Huella?\n\nEsto nos permite buscar mascotas perdidas en los grupos de la zona y avisarte si encontramos a la tuya.\n\nPara vincular, inicíá sesión en nuestra web y andá a tu perfil > Facebook."
          },
          {
            "type": "Footer",
            "label": "Volver al menú",
            "onClickAction": {
              "name": "navigate",
              "payload": {},
              "next_screen_id": "MAIN_MENU"
            }
          }
