# DATABASE_URL: PostgreSQL connection string.
# Required for both local development and Render deployment.
DATABASE_URL="postgresql://user:password@localhost:5432/sigotuhuella"

# JWT_SECRET: Secret key for generating auth tokens.
# Required. Change this to a strong random string in production.
JWT_SECRET="change-me-to-a-random-secret"

# SMTP settings for password recovery emails
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="tu-contraseña-smtp"

# VAPID keys for web push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-public-key-here"
VAPID_PRIVATE_KEY="your-private-key-here"
VAPID_SUBJECT="mailto:your-email@example.com"

# Apify API token for Facebook post scraping
# Get it from https://console.apify.com/settings/integrations
APIFY_TOKEN="your-apify-token-here"

# Instagram API
FACEBOOK_APP_ID=poner-el-app-id-de-facebook
FACEBOOK_APP_SECRET=poner-el-app-secret-de-facebook
INSTAGRAM_APP_ID=poner-el-instagram-app-id
INSTAGRAM_APP_SECRET=poner-el-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://sigotuhuella.online/api/instagram/callback
INSTAGRAM_VERIFY_TOKEN=sihuella-ig-2026
FACEBOOK_API_VERSION=v22.0

# Frontend URL for password reset links
FRONTEND_URL="http://localhost:5173"

# Groq API key for WhatsApp bot AI (vision + text classification)
# Get it from https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# WHATSAPP_AI_PRIMARY: if "true", bot uses AI first for intent detection (Groq)
# then falls back to keywords. In development keep "false" (keywords first).
WHATSAPP_AI_PRIMARY="false"

# RELAY_TOKEN: Token for the phone relay (Android Termux + Baileys).
# Must match between GitHub secret and the phone's relay.js
RELAY_TOKEN="generate-a-random-token-here"

# Admin user is auto-created on first startup:
# email: change-me@example.com
# password: change-me
