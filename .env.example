# DATABASE_URL: PostgreSQL connection string.
# Required for both local development and Render deployment.
DATABASE_URL="postgresql://user:password@localhost:5432/sigotuhuella"

# JWT_SECRET: Secret key for generating auth tokens.
# Required. Change this to a strong random string in production.
JWT_SECRET="change-me-to-a-random-secret"

# SMTP settings for password recovery emails (Gmail)
# Use Gmail App Password (not your regular password)
# Get it at: https://myaccount.google.com/security → Contraseñas de aplicación
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"

# Frontend URL for password reset links
FRONTEND_URL="http://localhost:5173"

# Admin user is auto-created on first startup:
#   email: sptortarolo@gmail.com
#   password: 1234
