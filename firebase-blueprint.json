{
  "entities": {
    "Pet": {
      "title": "Pet",
      "description": "A pet that is either lost, found, or up for adoption.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "species": { "type": "string", "enum": ["dog", "cat", "other"] },
        "breed": { "type": "string" },
        "color": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["lost", "found", "for_adoption", "adopted", "reunited"] 
        },
        "gender": { "type": "string", "enum": ["male", "female", "unknown"] },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "contactInfo": { "type": "string" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "imageUrl": { "type": "string" },
        "imageUrls": { 
          "type": "array", 
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 3
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "isAdminVerified": { "type": "boolean" }
      },
      "required": ["species", "status", "location", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "System user profiles with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "CollaborationAccount": {
      "title": "Collaboration Account",
      "description": "Payment accounts for donations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "bankName": { "type": "string" },
        "alias": { "type": "string" },
        "cbu": { "type": "string" },
        "cvu": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "bankName"]
    },
    "VolunteerRequest": {
      "title": "Volunteer Request",
      "description": "Requests from neighbors to join the network.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "residenceZone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted"] }
      },
      "required": ["fullName", "residenceZone", "whatsapp", "userId", "createdAt"]
    }
  },
  "firestore": {
    "pets": {
      "schema": "Pet",
      "description": "Public collection of all pet reports."
    },
    "users": {
      "schema": "User",
      "description": "Private collection for user roles and profiles."
    },
    "collaboration_accounts": {
      "schema": "CollaborationAccount",
      "description": "Public donation information."
    },
    "volunteer_requests": {
      "schema": "VolunteerRequest",
      "description": "Private requests to join the network."
    }
  }
}
